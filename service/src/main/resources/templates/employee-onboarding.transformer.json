{
  "formId": "employee-onboarding",
  "version": 2,
  "tableName": "form_employee_onboarding",
  "description": "New employee onboarding form",
  "schemaVersion": {
    "column": "schema_version",
    "sqlType": "INTEGER"
  },
  "auditColumns": {
    "createdAt": "created_at",
    "updatedAt": "updated_at",
    "submittedBy": "submitted_by"
  },
  "fields": [
    {
      "jsonPath": "personal.firstName",
      "column": "first_name",
      "sqlType": "TEXT",
      "nullable": false,
      "transform": { "toDb": "trimString" }
    },
    {
      "jsonPath": "personal.lastName",
      "column": "last_name",
      "sqlType": "TEXT",
      "nullable": false,
      "transform": { "toDb": "trimString" }
    },
    {
      "jsonPath": "personal.email",
      "column": "email",
      "sqlType": "TEXT",
      "nullable": false,
      "transform": { "toDb": "toLowerCase" },
      "validation": { "type": "string", "format": "email" }
    },
    {
      "jsonPath": "personal.startDate",
      "column": "start_date",
      "sqlType": "DATE",
      "nullable": false,
      "transform": { "toDb": "toLocalDate", "fromDb": "toIsoDateString" }
    },
    {
      "jsonPath": "role.department",
      "column": "department",
      "sqlType": "TEXT",
      "nullable": false
    },
    {
      "jsonPath": "role.title",
      "column": "job_title",
      "sqlType": "TEXT",
      "nullable": false
    },
    {
      "jsonPath": "role.salary",
      "column": "salary",
      "sqlType": "NUMERIC",
      "nullable": true,
      "transform": { "toDb": "toBigDecimal" }
    },
    {
      "jsonPath": "role.remote",
      "column": "is_remote",
      "sqlType": "BOOLEAN",
      "nullable": false,
      "defaultValue": false,
      "transform": { "toDb": "toBoolean" }
    },
    {
      "jsonPath": "equipment.preferences",
      "column": "equipment_prefs",
      "sqlType": "JSONB",
      "nullable": true,
      "transform": { "toDb": "jsonStringify", "fromDb": "jsonParse" }
    }
  ],
  "relations": [
    {
      "jsonPath": "certifications",
      "childTable": "form_employee_onboarding_certifications",
      "parentKey": "submission_id",
      "orderColumn": "item_index",
      "fields": [
        {
          "jsonPath": "name",
          "column": "cert_name",
          "sqlType": "TEXT",
          "nullable": false
        },
        {
          "jsonPath": "issuedBy",
          "column": "issued_by",
          "sqlType": "TEXT",
          "nullable": true
        },
        {
          "jsonPath": "expiryDate",
          "column": "expiry_date",
          "sqlType": "DATE",
          "nullable": true,
          "transform": { "toDb": "toLocalDate", "fromDb": "toIsoDateString" }
        }
      ]
    }
  ],
  "writeHooks": {
    "preValidation": ["normalizePhoneNumbersHook"],
    "postInsert": ["emitOnboardingEventHook"]
  },
  "readHooks": {
    "postAssemble": ["attachComputedFieldsHook"]
  }
}
